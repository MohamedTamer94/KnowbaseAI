# KnowbaseAI Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Groq API Configuration
# ============================================
# Get your API key from: https://console.groq.com
# Free tier includes 30 requests per minute
GROQ_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# REQUIRED: PostgreSQL Database Configuration
# ============================================
# Connection string for PostgreSQL database
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:password@localhost:5432/knowbaseai
DATABASE_URL=postgresql://user:password@localhost:5432/knowbaseai

# ============================================
# OPTIONAL: LLM Model Selection
# ============================================
# Default: llama-3.3-70b-versatile
# Other options:
#   - mixtral-8x7b-32768 (fast, good for short responses)
#   - gemma-7b-it (lightweight, fast)
#   - llama-2-70b-chat
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ============================================
# OPTIONAL: Chroma Vector Database Configuration
# ============================================
# Host: localhost for local development, "chroma" for Docker Compose
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ============================================
# OPTIONAL: Embedding Model Configuration
# ============================================
# Model for converting text to embeddings
# Default: all-MiniLM-L6-v2 (efficient, good quality)
# Other options:
#   - all-mpnet-base-v2 (better quality, larger)
#   - all-distilroberta-v1 (very fast)
#   - sentence-transformers/paraphrase-MiniLM-L6-v2
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Frontend URL (used for CORS and origin validation)
# Local development: http://localhost:5173
# Production: https://yourdomain.com
CLIENT_URL=http://localhost:5173


# ============================================
# OPTIONAL: Security Configuration
# ============================================
# JWT Secret for signing tokens
# Generate with: openssl rand -hex 32
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-key-change-in-production-use-32-characters

# ============================================
# OPTIONAL: Server Configuration
# ============================================
# Backend server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============================================
# OPTIONAL: Database Configuration
# ============================================
# PostgreSQL is required. Already configured above in REQUIRED section.
# For production, use a managed PostgreSQL service (AWS RDS, Google Cloud SQL, etc.)

# ============================================
# OPTIONAL: Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# OPTIONAL: Feature Flags
# ============================================
# Enable/disable specific features
DEBUG_MODE=false
ALLOW_REGISTRATION=true
ALLOW_ANONYMOUS_WIDGET=true

# ============================================
# OPTIONAL: Rate Limiting
# ============================================
# Requests per minute per user
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Maximum document size in MB
MAX_DOCUMENT_SIZE_MB=50

# ============================================
# OPTIONAL: Email Configuration (for future use)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@knowbaseai.com

# ============================================
# OPTIONAL: S3/Cloud Storage (for future use)
# ============================================
# AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=knowbaseai-documents

# ============================================
# Notes
# ============================================
# - Values with comments starting with # are optional
# - For development, only GROQ_API_KEY is required
# - Keep .env file secure and never commit to version control
# - Use different values for each environment (dev, staging, prod)
# - For Docker Compose, copy this to .env in the project root
