# Copy this file to .env and fill values
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE_URL=https://api.groq.ai
GROQ_LLM_MODEL=google/gemma-2-2b-it

# Chroma DB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Embedding model
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

CLIENT_URL=http://localhost:5173

# JWT Secret Key
JWT_SECRET_KEY=your-super-secret-key-change-in-production-use-32-characters